# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Virtual environment
.venv/
venv/
env/

# Logs
*.log

# Build artifacts
build/
dist/
# Локальная сборка (build_windows.bat): окружение .build-venv — сотни МБ,
# installer_out — готовый инсталлятор (~40 МБ), бутстраппер WebView2 качается
# с сайта Microsoft. Всё воспроизводится сборкой, в репозитории не нужно.
.build-venv/
installer_out/
MicrosoftEdgeWebview2Setup.exe

# Ресурс версии .exe: генерируется из webapp/__init__.py (__version__) на каждой
# сборке (OptiCIP-Dashboard.spec) — отслеживать его значит пачкать рабочее дерево.
version_info.txt

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Runtime caches
*.tmp

# Local sample/operator data
Архивы/
temp/
datalog/

# PyInstaller output
*.spec.bak

# Pytest
.pytest_cache/

# Node / JS-тесты
node_modules/
test-results/
playwright-report/
.playwright/
